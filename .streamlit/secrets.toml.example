# Streamlit Community Cloud: paste into App settings → Secrets (TOML format).
# Do not commit real values. Copy this file to secrets.toml only for local Streamlit secrets testing.
#
# TOML requires quoted strings for URLs (do NOT use .env style: DATABASE_URL=postgresql://... without quotes).

DATABASE_URL = "postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
VECTOR_BACKEND = "faiss"
# Strongly recommended on Streamlit Cloud (shared IPs → Semantic Scholar rate limits anonymous traffic).
# Get a key: https://www.semanticscholar.org/product/api — then uncomment and paste:
# SEMANTICSCHOLAR_API_KEY = "your-key-here"
# SKIP_AUTH = "0"
